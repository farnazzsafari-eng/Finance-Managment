NODE_ENV=production
PORT=5001
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/finance-management
JWT_SECRET=your-random-64-character-secret-key-here
ALLOWED_ORIGINS=https://your-app.railway.app

# Stripe (optional — needed for paid subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (optional — needed for monthly reminders)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=app-password-here
